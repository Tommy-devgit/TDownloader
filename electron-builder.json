{
  "appId": "com.tdownloader.app",
  "productName": "TDownloader",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json",
    "assets/**/*"
  ],
  "win": {
    "target": [
      "nsis"
    ],
    "icon": "assets/icon.png"
  },
  "mac": {
    "target": [
      "dmg",
      "zip"
    ],
    "category": "public.app-category.utilities"
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "category": "Utility"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
